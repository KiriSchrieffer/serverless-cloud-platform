DATABASE_URL=postgresql+asyncpg://serverless:serverless@postgres:5432/serverless
REDIS_URL=redis://redis:6379/0
JWT_SECRET_KEY=local-development-only-change-before-deploy
JWT_ALGORITHM=HS256
JWT_ISSUER=serverless-cloud-platform
JWT_AUDIENCE=serverless-cloud-platform-api
ACCESS_TOKEN_EXPIRE_MINUTES=60
PASSWORD_BCRYPT_ROUNDS=12
INVOCATION_RATE_LIMIT_CAPACITY=100
INVOCATION_RATE_LIMIT_PERIOD_SECONDS=60
INVOCATION_STREAM=invocations
INVOCATION_CONSUMER_GROUP=workers
DISPATCH_POLL_SECONDS=0.25
DISPATCH_BATCH_SIZE=100
PACKAGE_STORAGE_DIR=storage/packages
RESULT_STORAGE_DIR=storage/results
LOG_STORAGE_DIR=storage/logs
STORAGE_ROOT=storage
DEFAULT_MEMORY_LIMIT_MB=256
DEFAULT_CPU_LIMIT=0.5
DEFAULT_TIMEOUT_SECONDS=30
DEFAULT_MAX_ATTEMPTS=3
DEFAULT_MAX_CONCURRENCY=2
WORKER_HEARTBEAT_SECONDS=5
STALE_WORKER_SECONDS=15
PENDING_MESSAGE_CLAIM_COUNT=10
RUNTIME_IMAGE=serverless-python311-runtime:latest
WORKSPACE_ROOT=
MAX_INLINE_RESULT_BYTES=32768
MAX_LOG_BYTES=262144
